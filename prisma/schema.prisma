generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  passwordHash String?
  role        UserRole     @default(STUDENT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  resources   Resource[]   @relation("ResourceAuthor")
}

model Author {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  profession String
  bio        String
  avatarUrl  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  resources  Resource[] @relation("ResourceCatalogAuthor")
}

model Course {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  description   String
  level         CourseLevel    @default(BASIC)
  isPublished   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  announcements Announcement[]
  enrollments   Enrollment[]
  resources     Resource[]
  topics        Topic[]
}

model Topic {
  id          String       @id @default(cuid())
  title       String
  slug        String
  description String
  position    Int          @default(0)
  courseId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  resources   Resource[]
  simulations Simulation[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, slug])
}

model Resource {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  description      String
  type             ResourceType
  category         ResourceCategory @default(VIDEO)
  status           ResourceStatus   @default(DRAFT)
  storageUrl       String
  storageBucket    String?
  storagePath      String?
  originalFileName String?
  mimeType         String?
  thumbnailUrl     String?
  durationMinutes  Int?
  fileSizeMb       Float?
  publishedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  authorId         String
  authorProfileId  String?
  courseId         String
  topicId          String
  author           User             @relation("ResourceAuthor", fields: [authorId], references: [id])
  authorProfile    Author?          @relation("ResourceCatalogAuthor", fields: [authorProfileId], references: [id])
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  topic            Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Simulation {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  topicId     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  courseId    String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

enum UserRole {
  TEACHER
  STUDENT
  ASSISTANT
}

enum CourseLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum ResourceType {
  VIDEO
  PDF
}

enum ResourceCategory {
  VIDEO
  DOCUMENT
  BOOK
  BOOKLET
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
